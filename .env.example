# Copy this file to .env and fill in real values before deploying.
# In local development, none of this is required — sensible defaults
# in settings.py let `manage.py runserver` work out of the box.

# --- Core ---
SECRET_KEY=change-me-to-a-long-random-string-before-deploying
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
TIME_ZONE=Asia/Dhaka

# --- Email (leave blank / console backend for local dev) ---
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=Blood Finder <noreply@yourdomain.com>

# --- Site (used in password reset / verification email links) ---
SITE_DOMAIN=localhost:8000
SITE_PROTOCOL=http

# --- Production security (only take effect when DEBUG=False) ---
SECURE_SSL_REDIRECT=True
# Keep this True if deployed behind nginx/Railway/Render/Heroku/Cloudflare/an
# AWS ALB (almost always the case). Only set to False if gunicorn is exposed
# directly to the internet with no reverse proxy in front of it at all.
USE_X_FORWARDED_PROTO=True
